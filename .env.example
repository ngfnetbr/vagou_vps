# =============================================================================
# VAGOU - Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (Obrigatório)
# -----------------------------------------------------------------------------

# URL do projeto Supabase (encontre em: Supabase Dashboard > Settings > API > Project URL)
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"

# Chave anônima do Supabase (encontre em: Supabase Dashboard > Settings > API > anon public)
VITE_SUPABASE_ANON_KEY="sua-chave-anon-aqui"

# ID do projeto Supabase (o identificador único do projeto, ex: abcdefghijklmnop)
VITE_SUPABASE_PROJECT_ID="seu-project-id"

# -----------------------------------------------------------------------------
# OPCIONAIS (para funcionalidades específicas)
# -----------------------------------------------------------------------------

# Google Maps API Key (para mostrar mapas na seleção de CMEIs)
# VITE_GOOGLE_MAPS_API_KEY="sua-chave-google-maps"

# hCaptcha Site Key (se captcha estiver habilitado nas configurações)
# VITE_HCAPTCHA_SITE_KEY="sua-chave-hcaptcha"
